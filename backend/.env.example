# ==========================================================================
# Central de Inteligência Operacional (C12H) — variáveis de ambiente
# Copie este arquivo para `.env` e preencha a chave do provedor que você usa.
# ==========================================================================

# O assistente de IA é a ÚNICA chamada externa da POC.
# Sem chave, o assistente responde "indisponível" e o resto do app funciona normal.

# --- OpenAI ----------------------------------------------------------------
OPENAI_API_KEY=coloque-sua-chave-aqui
# Modelo do assistente. Default gpt-4o; gpt-4o-mini é a alternativa mais barata.
OPENAI_MODEL=gpt-4o

# --- CORS ------------------------------------------------------------------
# Origem permitida no CORS (frontend Vite). Default já cobre o dev local.
FRONTEND_ORIGIN=http://localhost:5173
